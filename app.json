{
  "expo": {
    "name": "MindMap BDS",
    "slug": "mindmap-bds-app",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "mindmapbds",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0f1117"
    },
    "android": {
      "package": "com.nguonnhachinhchu.mindmapbds",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "6e40a83a-ef57-46b4-9f84-b93086637aa5"
      }
    }
  }
}